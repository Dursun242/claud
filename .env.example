# ═══════════════════════════════════════════════════════════════
# ID MAÎTRISE — Variables d'environnement
# ═══════════════════════════════════════════════════════════════
#
# Copie ce fichier en `.env.local` à la racine du projet :
#
#   cp .env.example .env.local
#
# Puis remplace les valeurs placeholder par les vraies. `.env.local`
# est gitignoré (voir .gitignore), les secrets ne seront jamais commités.
#
# En production (Vercel), ces variables se configurent dans
# Dashboard → Settings → Environment Variables.
#
# Convention :
# - Les variables préfixées NEXT_PUBLIC_* sont exposées côté client
#   (bundle JS navigateur). Elles sont considérées comme publiques.
# - Les autres sont uniquement disponibles côté serveur (API routes).
#   Ne JAMAIS les préfixer NEXT_PUBLIC_ par erreur.
# ═══════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────
# SUPABASE — Base de données + Auth (OBLIGATOIRE)
# ─────────────────────────────────────────────────────────────
# Projet Supabase hébergeant la DB PostgreSQL et l'auth Google OAuth.
# À récupérer dans : Supabase Dashboard → Settings → API
#
# URL du projet (exposée au client — publique par design)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé anonyme (exposée au client — publique par design)
# Elle est protégée par les Row-Level Security policies côté DB.
# Utilisée par : supabaseClient.js (tous les appels depuis le navigateur)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxx

# Clé service role (SECRÈTE — ne JAMAIS l'exposer côté client)
# Bypasse les RLS policies, permet aux API routes serveur de faire
# des opérations admin (lecture du token Qonto, gestion des users,
# setup du bucket Storage…).
# Utilisée par :
#   - /api/admin/users       (gestion des utilisateurs autorisés)
#   - /api/upload            (upload de pièces jointes)
#   - /api/qonto             (lecture du token Qonto stocké en DB)
#   - /api/ai-qonto          (analyse IA des factures Qonto)
#   - /api/odoo/sign         (création de demande de signature)
#   - /api/setup-storage     (création du bucket Storage)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────
# ANTHROPIC — Assistant IA + extraction Vision (OBLIGATOIRE si on
# veut l'assistant IA et l'import photo des contacts/devis)
# ─────────────────────────────────────────────────────────────
# Clé API Anthropic (Claude). À récupérer sur console.anthropic.com.
# Budget conseillé : $10-20/mois suffit pour un usage normal
# (Claude Haiku 4.5 = très bon marché).
#
# Utilisée par :
#   - /api/claude             (assistant IA conversationnel dans l'app)
#   - /api/extract-contact    (import photo d'une carte de visite)
#   - /api/extract-os-data    (import photo d'un devis artisan → OS)
#   - /api/ai-qonto           (analyse des factures Qonto)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────
# PAPPERS — Recherche entreprises françaises (OBLIGATOIRE si on
# veut la recherche SIRET/dirigeants dans l'annuaire)
# ─────────────────────────────────────────────────────────────
# Clé API Pappers pour la recherche d'entreprises françaises par
# SIRET, nom ou dirigeant (pré-remplissage des contacts).
# Plan gratuit Pappers : suffisant pour un usage modéré.
# Docs : https://www.pappers.fr/api
#
# Utilisée par :
#   - /api/pappers (recherche dans la modale nouveau/édition contact)
PAPPERS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────
# ODOO SIGN — Signature électronique des Ordres de Service
# (OPTIONNEL — désactive la fonctionnalité "Signature" si vide)
# ─────────────────────────────────────────────────────────────
# Instance Odoo utilisée pour envoyer les OS en signature électronique
# aux 3 signataires (MOE, MOA, entreprise). Authentification via clé API.
#
# Utilisées par :
#   - /api/odoo/sign       (création de la demande de signature)
#   - /api/odoo/templates  (liste des templates disponibles)
#
# URL de l'instance Odoo (ex: https://maisonxxx.odoo.com)
ODOO_URL=https://your-instance.odoo.com

# Nom de la base Odoo (souvent identique au sous-domaine)
ODOO_DB=your-database-name

# Utilisateur Odoo (email de compte)
ODOO_USER=contact@id-maitrise.com

# Clé API Odoo (à créer dans Odoo → Préférences → API keys)
ODOO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────
# APP — Configuration générale
# ─────────────────────────────────────────────────────────────
# URL publique de l'app (utilisée par le callback OAuth Google pour
# rediriger après connexion). En dev local, laisse à http://localhost:3000.
# En prod Vercel, mets l'URL de production.
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ═══════════════════════════════════════════════════════════════
# QONTO — Note importante
# ═══════════════════════════════════════════════════════════════
# Le token Qonto (format login:secret-key) N'EST PAS une variable
# d'environnement. Il est saisi directement dans l'app, dans l'onglet
# « Qonto », et stocké dans la table `settings` de Supabase (clé
# 'qonto-token'). Le serveur le récupère à chaque appel via le service
# role key. Voir le commit 421e218 pour le détail du pattern.
#
# Conséquence : tu n'as rien à mettre dans .env.local pour Qonto.
# Tu vas juste saisir le token une fois dans l'UI après la première
# connexion.
# ═══════════════════════════════════════════════════════════════
